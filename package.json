{
  "name": "rvd-autonoma",
  "description": "RVD Autônoma — gestão de revenda de veículos (React + PocketBase)",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ngrok": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/iniciar-dev-ngrok.ps1",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/iniciar-rvd-autonoma.ps1",
    "start:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/iniciar-rvd-autonoma.ps1 -Dev",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.451.0",
    "pocketbase": "^0.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
